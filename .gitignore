# =========================
# Python
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd

# =========================
# Jupyter
# =========================
.ipynb_checkpoints/

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# Environment / local config
# =========================
.env
.venv/
venv/

# =========================
# Generated data
# Ignore contents but keep folder structure
# =========================

# raw
data/raw/literary_text/*
data/raw/scraped_images/*
data/raw/ai_generated_text/*
data/raw/image_derived_data/*

!data/raw/literary_text/.gitkeep
!data/raw/scraped_images/.gitkeep
!data/raw/ai_generated_text/.gitkeep
!data/raw/image_derived_data/.gitkeep

# cleaned
data/cleaned/literary_text/*
data/cleaned/scraped_images/*
data/cleaned/ai_generated_text/*
data/cleaned/image_derived_data/*

!data/cleaned/literary_text/.gitkeep
!data/cleaned/scraped_images/.gitkeep
!data/cleaned/ai_generated_text/.gitkeep
!data/cleaned/image_derived_data/.gitkeep

# processed
data/processed/literary_text/*
data/processed/scraped_images/*
data/processed/ai_generated_text/*
data/processed/image_derived_data/*

!data/processed/literary_text/.gitkeep
!data/processed/scraped_images/.gitkeep
!data/processed/ai_generated_text/.gitkeep
!data/processed/image_derived_data/.gitkeep

# =========================
# Outputs
# =========================
outputs/figures/*
outputs/tables/*
outputs/mappings/*
outputs/prompts/*
outputs/generated_images/*

!outputs/figures/.gitkeep
!outputs/tables/.gitkeep
!outputs/mappings/.gitkeep
!outputs/prompts/.gitkeep
!outputs/generated_images/.gitkeep

# =========================
# Figures
# =========================
figures/*
!figures/.gitkeep

